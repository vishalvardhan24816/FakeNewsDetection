# ============================================================
# Fake News Detector - environment configuration template
# ------------------------------------------------------------
# Copy this file to `.env` (which is gitignored) and fill in
# the values you want to use locally. Never commit `.env`.
# ============================================================

# --- LLM provider for the 5th validation step (web-presence gate) ---
# You only need ONE of these. Auto-detection prefers Gemini if both
# are set. To force a specific provider, set LLM_PROVIDER below.
#
# Gemini (recommended, generous free tier):
#   Get a key at https://aistudio.google.com/apikey
GOOGLE_GEMINI_API_KEY=

# Anthropic Claude (alternative, requires paid credits):
#   Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional overrides:
# LLM_PROVIDER=auto            # auto | gemini | anthropic | none
# GEMINI_MODEL=gemini-2.5-flash
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# --- Search backend for the web-presence check (5th step) ---
# "ddg" (default): DuckDuckGo news vertical. Free, no key, reliable.
# "google":        Direct scrape of Google News. Matches the original
#                  behavior, but Google may serve a JS-shell page; the
#                  check auto-falls-back to DuckDuckGo if Google returns 0.
# SEARCH_PROVIDER=ddg

# --- Flask web UI ---
# Used to sign session cookies. Generate a fresh value per environment.
FLASK_SECRET_KEY=
