# ============================================================
# Fake News Detector - environment configuration template
# ------------------------------------------------------------
# Copy this file to `.env` (which is gitignored) and fill in
# the values you want to use locally. Never commit `.env`.
# ============================================================

# --- Required for the 5th validation step (LLM contextual similarity) ---
# Get a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Optional: only needed if you re-enable the archived chatbot ---
HUGGINGFACE_API_TOKEN=

# --- Optional: only needed if you re-enable the archived "email the source" feature ---
# Use a Gmail App Password (NOT your real password):
# https://support.google.com/accounts/answer/185833
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# --- Optional: only needed if you re-enable the archived social-media DM feature ---
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
TWITTER_USERNAME=
TWITTER_PASSWORD=
FACEBOOK_USERNAME=
FACEBOOK_PASSWORD=
